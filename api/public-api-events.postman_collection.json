{
  "info": {
    "name": "Public API - Events",
    "description": "Postman collection for public event endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Events",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events?page=1&pageSize=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "events"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "pageSize",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Get Events with Search",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events?q=music&page=1&pageSize=20",
          "host": ["{{baseUrl}}"],
          "path": ["api", "events"],
          "query": [
            {
              "key": "q",
              "value": "music"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "pageSize",
              "value": "20"
            }
          ]
        }
      }
    },
    {
      "name": "Get Event by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/events/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "events", "1"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    }
  ]
}